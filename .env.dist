# iKHWEZI Production Environment Configuration
# Copy this file to .env and update values for your deployment

# ==================== BACKEND ====================
NODE_ENV=production
PORT=3001
JWT_SECRET=your_jwt_secret_here_change_this_in_production
ADMIN_KEY=your_admin_key_here_change_this_in_production

# ==================== DATABASE ====================
DB_TYPE=sqlite
DB_PATH=/app/storage/ikhwezi.db
DB_BACKUP_ENABLED=true
DB_AUTO_BACKUP_INTERVAL=86400000

# ==================== HOSTING ====================
APP_HOST=0.0.0.0
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com:8080

# ==================== RTMP/STREAMING ====================
RTMP_SERVER=rtmp://your-domain.com:1935/live
HLS_URL=https://your-domain.com:8081/hls
STREAM_QUALITY=high
STREAM_BITRATE=2500k

# ==================== CORS ====================
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
CORS_CREDENTIALS=true

# ==================== FILE UPLOAD ====================
MAX_VIDEO_SIZE=104857600
MAX_UPLOAD_TIMEOUT=300000
UPLOAD_TEMP_DIR=/tmp/uploads
VIDEO_STORAGE_DIR=/app/storage/uploads

# ==================== EMAIL (Optional) ====================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-domain.com

# ==================== AWS (Optional) ====================
AWS_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-ikhwezi-bucket
AWS_S3_REGION=us-east-1

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FILE=/app/logs/ikhwezi.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ==================== MONITORING ====================
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=
DATADOG_ENABLED=false

# ==================== PERFORMANCE ====================
CACHE_ENABLED=true
CACHE_TTL=3600
DATABASE_CONNECTION_LIMIT=10
REQUEST_TIMEOUT=30000
